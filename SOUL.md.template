## PLUGIN · git-plugin-amc

```yaml
plugins:
  git-plugin-amc:

    # ── Brand Identity ──────────────────────────────────────
    brand_name:    "{{BRAND_NAME}}"
    brand_slug:    "{{BRAND_SLUG}}"
    brand_niche:   "{{BRAND_NICHE}}"
    brand_mission: "{{BRAND_MISSION}}"
    markets:       "{{MARKETS}}"

    # ── Team ────────────────────────────────────────────────
    # All Lark users who message this bot are treated as brand team members.
    # No owner ID needed — there is no single approver.
    # team_lark_chat: the Lark group/bot that brand team uses to communicate with this agent

    # ── Platforms ───────────────────────────────────────────
    # active_platforms:  credentials confirmed → agent auto-publishes
    # pending_platforms: brand wants these, but no credentials yet →
    #                    agent drafts content, owner publishes manually
    # Both lists are filled by Bootstrap Mode after mcp.publisher.check_connection()
    active_platforms:  []
    pending_platforms: []

    # ── Paths ───────────────────────────────────────────────
    plugin_path: "./skills/"        # shared skills/ from git clone
    vault_path:  "./vault-{{BRAND_SLUG}}/"  # local mirror (primary is Lark Drive)

    # ── Shared Resources ────────────────────────────────────
    shared_resources:
      trending_radar:    "https://12eat-ai.sg.larksuite.com/docx/shared-trending-radar"
      workspaces_folder: "https://12eat-ai.sg.larksuite.com/drive/folder/PbugfutjllCDM0dqMiIlN0orgZd"
      vault_lark_folder: "{{VAULT_LARK_URL}}"   # created by Bootstrap via mcp.lark.drive

    # ── AMC Kanban ──────────────────────────────────────────
    # KANBAN_AGENT_API_KEY 也可通过环境变量传入（优先级高于此处）
    # 同等效果：在 MCP 配置中设置 KANBAN_AGENT_API_KEY=<your-key>
    # 所有社交媒体操作均通过 AMC Kanban 完成；仅当 Kanban 无法实现时，Agent 才自主寻找替代路径
    amc_kanban_api_key:  "{{AMC_KANBAN_API_KEY}}"

    # ── Bootstrap ───────────────────────────────────────────
    bootstrap:
      enabled: true
      trigger: "any unfilled placeholder present in plugins.git-plugin-amc"
      interview_script: "bootstrap/onboarding-flow/SKILL.md"
      scope: "plugins.git-plugin-amc"   # ONLY writes to this section, never touches the rest of SOUL.md
      on_complete:
        - fill_placeholders:      "write all collected values into plugins.git-plugin-amc"
        - create_lark_vault:      "mcp.lark.drive → subfolder in {{LARK_WORKSPACES_URL}}, name={{BRAND_SLUG}}"
        - upload_vault_templates: "upload vault-templates/ into Lark Drive vault folder"
        - notify_team:            "✅ 配置完成，我正式开始工作了。内容将直接发布，请到各平台查看并随时发消息给我反馈。"
        - exit_bootstrap:         true
```

