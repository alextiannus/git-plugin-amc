# ── Brand-specific generated files ──────────────────────────────
# Brand SOUL files (generated by Bootstrap Mode — one per brand instance)
SOUL_*.md

# Local vault folders (operational records, if mirrored locally)
# Primary storage is Lark Drive; these are optional local mirrors.
vault-*/
!vault-templates/
!vault-templates/**

# Legacy — no longer created (plugin install is via openclaw plugins install)
content-skill-graph-*/
.fb-engine-lock-*.yaml

# ── macOS ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Editors ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Brand-customized skill files (written by Bootstrap, never overwritten by git pull) ──
# Generic defaults live in the corresponding .template files (tracked by git).
# Bootstrap writes brand-specific content into skill subdirectory SKILL.md files.
skills/localization/brand-voice/SKILL.md
skills/compliance/allergen-gate/SKILL.md
skills/localization/bilingual-gate/SKILL.md

# ── Build output (generated by tsc, not committed) ───────────────
dist/
node_modules/

# ── Temp files ───────────────────────────────────────────────────
*.bak
*.tmp
